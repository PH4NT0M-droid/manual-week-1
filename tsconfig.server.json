{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist/server",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "lib": ["ES2022"],
    "allowJs": false
  },
  "include": ["src/server/**/*.ts", "src/shared/**/*.ts"]
}